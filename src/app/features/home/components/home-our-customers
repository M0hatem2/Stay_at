<div class="relative max-w-4xl mx-auto">
  <button
    (click)="previousReview()"
    class="absolute top-1/2 -translate-y-1/2 left-0 -ml-4 md:-ml-16 z-20 p-3 bg-white rounded-full shadow-lg hover:gradient-primary-btn hover:text-white transition-colors group"
    [disabled]="currentReviewIndex === 0">
    <svg
      xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      class="lucide lucide-chevron-left w-6 h-6" aria-hidden="true">
      <path d="m15 18-6-6 6-6"></path>
    </svg>
  </button>
  
  <button
    (click)="nextReview()"
    class="absolute top-1/2 -translate-y-1/2 right-0 -mr-4 md:-mr-16 z-20 p-3 bg-white rounded-full shadow-lg hover:gradient-primary-btn hover:text-white transition-colors group"
    [disabled]="currentReviewIndex === reviews.length - 1">
    <svg
      xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      class="lucide lucide-chevron-right w-6 h-6" aria-hidden="true">
      <path d="m9 18 6-6-6-6"></path>
    </svg>
  </button>
  
  <div class="relative h-[400px] md:h-[350px]">
    <div class="absolute inset-0" style="opacity: 1; transform: none;">
      <div class="bg-white rounded-3xl shadow-xl p-8 md:p-12 h-full flex flex-col justify-between">
        <div class="flex items-start gap-4 mb-6">
          <div class="flex-shrink-0">
            <div class="w-16 h-16 bg-gradient-to-br from-[#C4A962] to-[#D4B972] rounded-2xl flex items-center justify-center shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="lucide lucide-quote w-8 h-8 text-white" aria-hidden="true">
                <path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path>
                <path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path>
              </svg>
            </div>
          </div>
          <div class="flex-1">
            <div class="flex gap-1 mb-3">
              <svg *ngFor="let star of renderStars" xmlns="http://www.w3.org/2000/svg"
                width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="lucide lucide-star w-5 h-5 fill-yellow-400 text-yellow-400" aria-hidden="true">
                <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
              </svg>
              <svg *ngFor="let star of renderEmptyStars" xmlns="http://www.w3.org/2000/svg"
                width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="lucide lucide-star w-5 h-5 text-gray-300" aria-hidden="true">
                <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
              </svg>
            </div>
          </div>
        </div>
        
        <p class="text-gray-700 text-lg leading-relaxed mb-8 flex-1">"{{ currentReview?.comment }}"</p>
        
        <div class="flex items-center gap-4">
          <img
            [src]="currentReview?.avatar"
            [alt]="currentReview?.name"
            class="w-16 h-16 rounded-full object-cover ring-4 ring-[#C4A962]/20">
          <div>
            <h4 class="text-gray-900">{{ currentReview?.name }}</h4>
            <p class="text-gray-600 text-sm">{{ currentReview?.role }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="flex items-center justify-center gap-2 mt-8">
    <button
      *ngFor="let review of reviews; let i = index"
      (click)="goToReview(i)"
      class="h-2 rounded-full transition-all"
      [class.w-8]="i === currentReviewIndex"
      [class.gradient-primary-btn]="i === currentReviewIndex"
      [class.w-2]="i !== currentReviewIndex"
      [class.bg-gray-300]="i !== currentReviewIndex"
      [class.hover:bg-gray-400]="i !== currentReviewIndex">
    </button>
  </div>
</div>